# =============================================================================
# IDEORA – Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase (Required for authentication and data persistence)
# Get these from: https://supabase.com → Project Settings → API
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# -----------------------------------------------------------------------------
# N8N Webhook (Optional – powers live trend data fetching)
# Set up your N8N workflow and paste the webhook URL here.
# The app works without this; dashboard will show demo data.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/your-id

# -----------------------------------------------------------------------------
# App URL (Required for production – used in OG tags and redirects)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=https://your-domain.com
